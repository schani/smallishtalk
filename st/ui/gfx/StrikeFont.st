"UI-Graphics L2 (UI.md §5.5): a Smalltalk-80 style strike font. All glyphs live
 side-by-side in one Form (`glyphs`), a fixed `width` apart; `displayString:...`
 BitBlts each glyph left-to-right. The baked-in default font data lives in
 DefaultFont.st (generated by st/tools/gen_font.py)."

Object subclass: #StrikeFont
	instanceVariableNames: 'glyphs width height first count'
	classVariableNames: ''
	poolDictionaries: ''
	category: 'UI-Graphics'!

!StrikeFont class methodsFor: 'instances'!
default
	"the single baked-in font, built once and cached in a global."
	DefaultStrikeFont isNil ifTrue: [DefaultStrikeFont := self buildDefault].
	^DefaultStrikeFont!
buildDefault
	| f strike bits |
	bits := self defaultGlyphBits.
	strike := Form width: self defaultWidth * self defaultCount height: self defaultHeight.
	1 to: bits size do: [:i | strike bits at: i put: (bits at: i)].
	f := self new.
	f setGlyphs: strike width: self defaultWidth height: self defaultHeight
		first: self defaultFirst count: self defaultCount.
	^f! !

!StrikeFont methodsFor: 'accessing'!
setGlyphs: aForm width: w height: h first: fst count: c
	glyphs := aForm.
	width := w.
	height := h.
	first := fst.
	count := c!
glyphs
	^glyphs!
width
	^width!
height
	^height!
widthOfString: aString
	^aString size * width! !

!StrikeFont methodsFor: 'displaying'!
displayString: aString on: aForm at: aPoint
	"paint text over the background (rule 7 = or)."
	^self displayString: aString on: aForm at: aPoint rule: 7!
displayString: aString on: aForm at: aPoint rule: aRule
	"blit each glyph left-to-right with aRule; skip chars outside the font's
	 range. `aString at: i` answers the byte/code at the VM level. Rule 6 (xor)
	 over a black bar gives reverse-video (white glyphs), used for selection."
	| x code bb |
	x := aPoint x.
	1 to: aString size do: [:i |
		code := aString at: i.
		(code >= first and: [code < (first + count)]) ifTrue: [
			bb := BitBlt new.
			bb destForm: aForm.
			bb sourceForm: glyphs.
			bb combinationRule: aRule.
			bb destX: x.
			bb destY: aPoint y.
			bb width: width.
			bb height: height.
			bb sourceX: (code - first) * width.
			bb sourceY: 0.
			bb clipX: 0.
			bb clipY: 0.
			bb clipWidth: aForm width.
			bb clipHeight: aForm height.
			bb copyBits].
		x := x + width].
	^self! !
